{
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit"
  },
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "emmet.showExpandedAbbreviation": "never",
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/.next": true,
    "**/.turbo": true,
    "**/.cache": true,
    "**/.pnpm-store": true,
    "**/coverage": true,
    "**/dist": true,
    "**/build": true,
    "**/storybook-static": true,
    "**/.vercel": true,
    "**/.convex": true,
    "**/.sanity": true,
    "**/.playwright": true,
    "**/*.tsbuildinfo": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/.turbo": true,
    "**/.cache": true,
    "**/.pnpm-store": true,
    "**/coverage": true,
    "**/dist": true,
    "**/build": true,
    "**/storybook-static": true,
    "**/.vercel": true,
    "**/.convex": true,
    "**/.sanity": true,
    "**/.playwright": true,
    "**/*.tsbuildinfo": true
  },
  "files.watcherExclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/.turbo": true,
    "**/.cache": true,
    "**/.pnpm-store": true,
    "**/coverage": true,
    "**/dist": true,
    "**/build": true,
    "**/storybook-static": true,
    "**/.vercel": true,
    "**/.convex": true,
    "**/.sanity": true,
    "**/.playwright": true,
    "**/*.tsbuildinfo": true
  },
  "prettier.enable": false,
  "typescript.tsdk": "node_modules/typescript/lib",
  "tailwindCSS.experimental.configFile": "packages/design-system/styles/globals.css"
}
