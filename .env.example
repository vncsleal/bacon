# ─────────────────────────────────────────
# bacon · root .env.example
# ─────────────────────────────────────────
# Copy to .env.local and fill in your values.
# Generate BETTER_AUTH_SECRET: openssl rand -base64 32

# ── Convex ────────────────────────────────
CONVEX_DEPLOYMENT=""            # e.g. dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=""       # e.g. https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=""  # e.g. https://your-deployment.convex.site

# ── Better Auth ───────────────────────────
BETTER_AUTH_SECRET=""
SITE_URL="http://localhost:3000"

# ── Stripe ────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_FREE_PRICE_ID=""
STRIPE_PRO_PRICE_ID=""

# ── Email (Resend) ────────────────────────
RESEND_FROM=""                  # e.g. noreply@yourdomain.com
RESEND_TOKEN=""                 # starts with re_

# ── Observability (Better Stack) ──────────
BETTERSTACK_API_KEY=""
BETTERSTACK_URL=""

# ── Feature Flags ─────────────────────────
FLAGS_SECRET=""

# ── Security (Arcjet) ─────────────────────
ARCJET_KEY=""                   # starts with ajkey_

# ── Rate Limiting (Upstash Redis) ─────────
UPSTASH_REDIS_REST_URL=""       # e.g. https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=""     # starts with AYQe...

# ── Webhooks (Svix) ───────────────────────
SVIX_TOKEN=""                   # starts with sk_ or testsk_

# ── Collaboration (Liveblocks) ────────────
LIVEBLOCKS_SECRET=""            # starts with sk_

# ── Notifications (Knock) ─────────────────
KNOCK_SECRET_API_KEY=""
NEXT_PUBLIC_KNOCK_API_KEY=""
NEXT_PUBLIC_KNOCK_FEED_CHANNEL_ID=""

# ── CMS (BaseHub) ─────────────────────────
BASEHUB_TOKEN=""      # Get from https://basehub.com/dashboard/settings

# ── Analytics ─────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=""      # starts with phc_
NEXT_PUBLIC_POSTHOG_HOST=""
NEXT_PUBLIC_GA_MEASUREMENT_ID="" # optional, starts with G-

# ── App URLs ──────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WEB_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3002"
NEXT_PUBLIC_DOCS_URL="http://localhost:3004"
